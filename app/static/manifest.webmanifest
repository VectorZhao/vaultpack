      "purpose": "any"
    },
    {
      "src": "/static/vaultpack-icon-adaptive-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/static/vaultpack-icon-adaptive-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
