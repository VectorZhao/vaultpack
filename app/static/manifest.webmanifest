{
  "name": "vaultpack",
  "short_name": "vaultpack",
  "description": "多节点文件夹备份控制台",
  "lang": "zh-CN",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "orientation": "any",
  "background_color": "#0d1118",
